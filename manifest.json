{
  "manifest_version": 3,
  "name": "Crossword to Anki",
  "version": "0.1.0",
  "description": "Capture clue/answer pairs from NYT crosswords and send them to Anki via AnkiConnect.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.nytimes.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/crosswords/*",
        "https://www.nytimes.com/games/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Crossword to Anki"
  },
  "options_page": "options.html",
  "commands": {
    "capture-clue": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Capture the active crossword clue and answer"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
